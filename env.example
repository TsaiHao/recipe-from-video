# DeepSeek (default LLM provider)
DEEPSEEK_API_KEY=

# Cloudflare Workers AI (optional, for --stt cloudflare)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# AWS credentials (optional, for --stt aws)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=

# Bytedance Volcano Engine (optional, for --stt volcano)
VOLCANO_APP_KEY=
VOLCANO_ACCESS_KEY=

# Google Cloud (optional, for --stt google)
GOOGLE_APPLICATION_CREDENTIALS=
